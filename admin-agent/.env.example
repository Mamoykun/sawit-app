# Copy file ini ke .env dan isi values sesuai setup kamu.
# JANGAN commit .env ke git (sudah di .gitignore).

# ─── Claude API (Anthropic) ──────────────────────────────────────────────────
# Pakai existing key dari Sawitku backend. Get di https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Get token dari @BotFather di Telegram (/newbot)
TELEGRAM_BOT_TOKEN=1234567890:ABCdef-GhI...

# ─── Sawitku Backend ─────────────────────────────────────────────────────────
# URL public backend Sawitku (HTTPS recommended di production)
SAWITKU_API_BASE=https://api.sawitku.id

# Random secret yang sama dengan ADMIN_AGENT_API_KEY di backend env
# Generate: openssl rand -hex 32
SAWITKU_AGENT_KEY=your_generated_secret_64_chars_hex

# ─── OpenClaw Optional ───────────────────────────────────────────────────────
OPENCLAW_LOG_LEVEL=info
