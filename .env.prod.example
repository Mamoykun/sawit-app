# ==============================================================
# Sawitku — Production Environment Variables
# Usage: cp .env.prod.example .env  (lalu isi semua nilai)
# ==============================================================

# --- Domain (WAJIB) ---
# Domain yang sudah ada A record ke IP server ini
SAWITKU_DOMAIN=api.sawitku.id

# --- PostgreSQL (WAJIB) ---
POSTGRES_DB=sawitku_db
POSTGRES_USER=sawitku_user
POSTGRES_PASSWORD=GANTI_PASSWORD_KUAT_MINIMAL_32_KARAKTER

# --- JWT (WAJIB) ---
# Generate: openssl rand -hex 32
JWT_SECRET=GANTI_DENGAN_STRING_RANDOM_MINIMAL_64_KARAKTER

# --- Claude AI (WAJIB untuk fitur AI) ---
CLAUDE_API_KEY=sk-ant-XXXXX
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
CLAUDE_MODEL_SONNET=claude-sonnet-4-20250514

# --- Admin ---
# Email admin yang bisa akses endpoint /admin (pisahkan koma)
ADMIN_EMAILS=admin@sawitku.id
# API key untuk OpenClaw admin agent (generate: openssl rand -hex 16)
ADMIN_AGENT_API_KEY=GANTI_API_KEY_ADMIN_AGENT

# --- Email (pilih PROVIDER) ---
# Provider: smtp | log (log = cetak di console, untuk testing)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@sawitku.id
SMTP_PASSWORD=GANTI_APP_PASSWORD_GMAIL
EMAIL_FROM=noreply@sawitku.id
RESET_URL_TEMPLATE=https://app.sawitku.id/reset-password?token={token}

# --- CORS ---
# Pisahkan koma jika lebih dari satu origin
CORS_ALLOWED_ORIGINS=https://app.sawitku.id

# --- Spring ---
SPRING_PROFILES_ACTIVE=prod

# --- Versi image (opsional, default: latest) ---
SAWITKU_VERSION=latest

# --- Backup (opsional) ---
# Berapa hari menyimpan backup sebelum dihapus otomatis
BACKUP_RETENTION_DAYS=7

# --- Let's Encrypt (opsional, tapi disarankan) ---
# Email untuk notifikasi expiry sertifikat
ACME_EMAIL=admin@sawitku.id
